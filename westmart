                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-3 text-xs">
                        <span><i class="fa-solid fa-weight-hanging mr-1 text-brand"></i><span id="modal-weight"></span></span>
                        <span><i class="fa-solid fa-ruler-combined mr-1 text-brand"></i><span id="modal-dimensions"></span></span>
                        <span><i class="fa-solid fa-truck mr-1 text-brand"></i><span id="modal-delivery"></span></span>
