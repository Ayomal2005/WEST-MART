                    </div>
                </div>
                
                <form id="order-form" onsubmit="submitOrder(event)" class="space-y-4">
                    <div class="grid md:grid-cols-2 gap-4">
                        <input type="text" id="customer-name" placeholder="Full Name *" class="form-input w-full" required>
                        <input type="tel" id="whatsapp-phone" placeholder="WhatsApp Number *" class="form-input w-full" required>
                        <input type="text" id="city" placeholder="City *" class="form-input w-full" required>
                        <input type="text" id="alt-phone" placeholder="Alt Phone (Optional)" class="form-input w-full">
                    </div>
                    <textarea id="address" placeholder="Delivery Address *" rows="2" class="form-input w-full" required></textarea>
                    
                    <div class="flex items-center gap-3">
                        <label class="font-semibold text-sm">Quantity:</label>
                        <input type="number" id="qty-input" min="1" value="1" class="form-input w-20 text-center" required>
                    </div>
                    
                    <div>
                        <p class="font-semibold text-sm mb-3"><i class="fa-solid fa-credit-card mr-1"></i>Payment Method</p>
                        <div class="grid md:grid-cols-2 gap-3">
                            <div id="cod-card" class="payment-card selected" onclick="document.getElementById('payment-cod').checked=true; updatePaymentSelection();">
