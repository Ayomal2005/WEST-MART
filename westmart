                </div>
                <div class="w-full md:w-72 relative">
                    <i class="fa-solid fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                    <input type="text" id="search-input" placeholder="Search products..." class="w-full pl-9 pr-3 py-2 rounded-full text-sm text-gray-800 bg-white shadow-md focus:outline-none focus:ring-2 focus:ring-brand/50">
